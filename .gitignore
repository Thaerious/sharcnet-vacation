# Ignore files in root
/*

# Allow specific root directories
!client-src/
!doc/
!server/
!www/
!tests/
!db/

# Ignore everything in db/ except specific files
db/*
!db/empty.db
!db/default.d

# Allow specific root files
!.env.example
!.gitignore
!.dockerignore
!package.json
!package-lock.json
!Dockerfile
!docker-compose.yml
!Makefile

# Allow specific non-root files
!db/empty.db