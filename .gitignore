# Ignore files in root
/*

# Allow specific root directories
!client-src/
!doc/
!server/
!www/
!tests/
!db/

# Ignore everything in db/ except specific files
db/*
!db/empty.db
!db/default.db

# Allow specific root files
!.env.example
!.gitignore
!package.json
!package-lock.json

# Allow specific non-root files
!db/empty.db